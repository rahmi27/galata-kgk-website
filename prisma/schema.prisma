generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model AdminUser {
  id           Int      @id @default(autoincrement())
  username     String   @unique
  passwordHash String
  name         String
  createdAt    DateTime @default(now())
}

model AdminLoginAttempt {
  id        Int      @id @default(autoincrement())
  username  String
  ipAddress String
  createdAt DateTime @default(now())

  @@index([username, ipAddress, createdAt])
}

model Event {
  id              Int      @id @default(autoincrement())
  title           String
  slug            String   @unique
  description     String
  longDescription String
  date            DateTime?
  location        String
  imageUrl        String?
  imageAlt        String?
  category        String
  createdAt       DateTime @default(now())

  @@index([date])
}

model TeamMember {
  id         Int          @id @default(autoincrement())
  name       String
  role       String
  photoUrl   String?
  photoAlt   String?
  order      Int
  createdAt  DateTime     @default(now())
  categoryId Int
  category   TeamCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  @@index([categoryId, order])
}

model TeamCategory {
  id      Int          @id @default(autoincrement())
  name    String       @unique
  slug    String       @unique
  order   Int
  members TeamMember[]

  @@index([order])
}

model Sponsor {
  id          Int         @id @default(autoincrement())
  name        String
  logoUrl     String
  logoAlt     String?
  websiteUrl  String?
  description String?
  order       Int
  createdAt   DateTime    @default(now())
  tierId      Int
  tier        SponsorTier @relation(fields: [tierId], references: [id], onDelete: Restrict)

  @@index([tierId, order])
}

model SponsorTier {
  id       Int       @id @default(autoincrement())
  name     String    @unique
  slug     String    @unique
  order    Int
  sponsors Sponsor[]

  @@index([order])
}

model ContactSubmission {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  message   String
  createdAt DateTime @default(now())
  isRead    Boolean  @default(false)

  @@index([email, createdAt])
}

model MembershipApplication {
  id            Int      @id @default(autoincrement())
  fullName      String
  email         String
  studentNumber String?
  department    String
  phone         String?
  motivation    String
  createdAt     DateTime @default(now())
  status        String   @default("beklemede")

  @@index([email, createdAt])
}

model SiteStat {
  id    Int    @id @default(autoincrement())
  label String
  value String
  order Int

  @@index([order])
}
