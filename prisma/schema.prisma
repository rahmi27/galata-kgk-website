generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Event {
  id              Int      @id @default(autoincrement())
  title           String
  slug            String   @unique
  description     String
  longDescription String
  date            DateTime
  location        String
  imageUrl        String?
  category        String
  createdAt       DateTime @default(now())

  @@index([date])
}

model TeamMember {
  id         Int      @id @default(autoincrement())
  name       String
  role       String
  department String
  photoUrl   String?
  order      Int
  createdAt  DateTime @default(now())

  @@index([department, order])
}

model ContactSubmission {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  message   String
  createdAt DateTime @default(now())
  isRead    Boolean  @default(false)
}

model SiteStat {
  id    Int    @id @default(autoincrement())
  label String
  value String
  order Int

  @@index([order])
}
