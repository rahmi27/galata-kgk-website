# SQLite development database
DATABASE_URL="file:./dev.db"

# Generate a random value of at least 32 bytes before running the app.
AUTH_SECRET="replace-with-a-long-random-secret"
AUTH_URL="http://localhost:3000"

# Used for canonical URLs, Open Graph metadata, sitemap.xml and robots.txt.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Yalnızca geliştirme ortamında Next.js dev sunucusuna erişmesine izin verilen
# ngrok/cloudflared alan adları. Virgülle ayırarak daraltabilir veya çoğaltabilirsiniz.
DEV_TUNNEL_ORIGINS="*.ngrok-free.dev,*.ngrok.app,*.ngrok.io,*.trycloudflare.com"

# Temporary password for the seeded `admin` user (minimum 12 characters).
ADMIN_SEED_PASSWORD="replace-with-a-strong-temporary-password"
