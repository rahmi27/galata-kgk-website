# Required for Vercel production deployments
# Pooled Neon connection used by Prisma Client at runtime (host contains -pooler)
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler/DATABASE?sslmode=require"
# Direct Neon connection used only by Prisma CLI migrations (host does not contain -pooler)
DIRECT_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"
AUTH_SECRET="replace-with-a-long-random-secret"
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_replace-with-your-token"

# Required only while running `npx prisma db seed`
ADMIN_SEED_PASSWORD="replace-with-a-strong-temporary-password"

# Optional local development settings
DEV_TUNNEL_ORIGINS="*.ngrok-free.dev,*.ngrok.app,*.ngrok.io,*.trycloudflare.com"

# Optional canonical URL override. Vercel domains are detected automatically.
# NEXT_PUBLIC_SITE_URL="https://example.com"
